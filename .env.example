# Optional alert dispatch. Alerts are displayed in the dashboard without these.
ALERTS_ENABLED=0
ALERT_COOLDOWN_HOURS=6

# Email alerts
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_TLS=1
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_SUBJECT=AI Bubble Monitor alert

# Discord alerts
ALERT_DISCORD_WEBHOOK_URL=

# Generic JSON webhook alerts
ALERT_WEBHOOK_URL=

# Telegram is intentionally not supported in this project.
